# Variables de entorno a nivel de proyecto (no las del backend, que viven en backend/.env).
# Uso previsto: URL base de la API para el frontend (Fase 4) y, si se activa
# infra/docker-compose.yml en el futuro, el .env que docker compose carga por defecto
# cuando se invoca desde la raíz del repo.

# URL donde el frontend (Vite + React, Fase 4) espera encontrar el backend FastAPI.
VITE_API_BASE_URL=http://localhost:8000
